{
    "name": "phord/core",
    "description": "Phord PHP↔BEAM bridge — framework-agnostic core (back-channel, cache client, worker protocol, framing).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Phord\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phord\\Tests\\": "tests/"
        }
    }
}
